# Configuración de la fábrica de repositorios
# Valores posibles para REPO_TYPE: sqlite (por defecto), json
REPO_TYPE=sqlite

# Ejemplo: para usar el repositorio JSON, establecer
#REPO_TYPE=json

# Rutas (opcional)
SQLITE_PATH=students.db
JSON_PATH=students.json

# Puertos
# Puerto para la API REST
API_PORT=5001
# Puerto para el servidor MCP (SSE)
MCP_PORT=9000


